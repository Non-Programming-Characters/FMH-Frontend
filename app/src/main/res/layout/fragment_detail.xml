<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header с красным фоном -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@color/red_cross">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_revert"
                android:contentDescription="Назад"
                android:padding="12dp"
                android:layout_margin="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <ImageView
                android:id="@+id/ivDetailIcon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:background="@drawable/circle_bg_white"
                android:padding="16dp"
                android:src="@drawable/ic_blood"/>
        </FrameLayout>

        <!-- Контент -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Заголовок -->
            <TextView
                android:id="@+id/tvDetailTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Заголовок"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#333333"/>

            <!-- Краткое описание -->
            <TextView
                android:id="@+id/tvDetailShortDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Краткое описание"
                android:textSize="16sp"
                android:textColor="#E62129"
                android:textStyle="italic"/>

            <!-- Разделитель -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="24dp"
                android:background="#DDDDDD"/>

            <!-- Полное описание -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Как оказать помощь"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"/>

            <TextView
                android:id="@+id/tvDetailFullDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Полное описание оказания помощи..."
                android:textSize="16sp"
                android:textColor="#666666"
                android:lineSpacingExtra="4dp"/>

            <!-- Сложность -->
            <TextView
                android:id="@+id/tvDetailDifficulty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Сложность: ★★★"
                android:textSize="16sp"
                android:textColor="#FF9800"
                android:textStyle="bold"/>

            <!-- Источники -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Источники информации"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"/>

            <TextView
                android:id="@+id/tvDetailSource"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Источник: Минздрав РФ"
                android:textSize="14sp"
                android:textColor="#888888"/>

            <!-- Отступ снизу -->
            <View
                android:layout_width="match_parent"
                android:layout_height="48dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>